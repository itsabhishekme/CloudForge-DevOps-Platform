# ==========================================================
# CloudForge DevOps Platform
# Docker Environment Variables
# ==========================================================

# ----------------------------------------------------------
# Application
# ----------------------------------------------------------
APP_NAME=CloudForge DevOps Platform
APP_VERSION=1.0.0
NODE_ENV=development

# ----------------------------------------------------------
# Frontend
# ----------------------------------------------------------
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_TELEMETRY_DISABLED=1

# ----------------------------------------------------------
# Backend
# ----------------------------------------------------------
BACKEND_PORT=5000
CLIENT_URL=http://localhost:3000

# ----------------------------------------------------------
# MongoDB
# ----------------------------------------------------------
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=rootpassword
MONGO_INITDB_DATABASE=cloudforge

MONGO_USERNAME=cloudforge
MONGO_PASSWORD=cloudforge123

MONGO_URI=mongodb://root:rootpassword@mongodb:27017/cloudforge?authSource=admin

# ----------------------------------------------------------
# NGINX
# ----------------------------------------------------------
NGINX_PORT=80

# ----------------------------------------------------------
# Prometheus
# ----------------------------------------------------------
PROMETHEUS_PORT=9090

# ----------------------------------------------------------
# Grafana
# ----------------------------------------------------------
GRAFANA_PORT=3001
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin123

# ----------------------------------------------------------
# Elasticsearch
# ----------------------------------------------------------
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=elastic123

# ----------------------------------------------------------
# Kibana
# ----------------------------------------------------------
KIBANA_PORT=5601

# ----------------------------------------------------------
# Logstash
# ----------------------------------------------------------
LOGSTASH_PORT=5044

# ----------------------------------------------------------
# Jenkins
# ----------------------------------------------------------
JENKINS_PORT=8080
JENKINS_AGENT_PORT=50000

# ----------------------------------------------------------
# Kubernetes
# ----------------------------------------------------------
K8S_NAMESPACE=cloudforge

# ----------------------------------------------------------
# AWS
# (Leave blank locally or override securely in CI/CD)
# ----------------------------------------------------------
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ACCOUNT_ID=