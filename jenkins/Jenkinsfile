pipeline {
    agent any

    environment {
        APP_NAME = "cloudforge-devops-platform"
        FRONTEND_IMAGE = "cloudforge/frontend"
        BACKEND_IMAGE = "cloudforge/backend"
        DOCKER_COMPOSE_FILE = "docker/docker-compose.prod.yml"
    }

    options {
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    triggers {
        githubPush()
    }

    stages {

        stage('Checkout Source') {
            steps {
                echo "Checking out source code..."
                checkout scm
            }
        }

        stage('Install Frontend Dependencies') {
            steps {
                dir('apps/frontend') {
                    sh 'npm ci'
                }
            }
        }

        stage('Build Frontend') {
            steps {
                dir('apps/frontend') {
                    sh 'npm run build'
                }
            }
        }

        stage('Install Backend Dependencies') {
            steps {
                dir('apps/backend') {
                    sh 'npm ci'
                }
            }
        }

        stage('Build Backend') {
            steps {
                dir('apps/backend') {
                    sh 'npm run build'
                }
            }
        }

        stage('Run Tests') {
            steps {
                echo "Running application tests..."

                dir('apps/frontend') {
                    sh 'npm test || true'
                }

                dir('apps/backend') {
                    sh 'npm test || true'
                }
            }
        }

        stage('Build Docker Images') {
            steps {
                sh """
                docker compose -f ${DOCKER_COMPOSE_FILE} build
                """
            }
        }

        stage('Start Containers') {
            steps {
                sh """
                docker compose -f ${DOCKER_COMPOSE_FILE} up -d
                """
            }
        }

        stage('Docker Status') {
            steps {
                sh 'docker ps'
            }
        }

        stage('Cleanup') {
            steps {
                sh 'docker image prune -f'
            }
        }
    }

    post {

        success {
            echo "CloudForge DevOps Platform deployed successfully."
        }

        failure {
            echo "Pipeline failed."
        }

        always {
            archiveArtifacts artifacts: '**/package*.json', fingerprint: true

            cleanWs()
        }
    }
}