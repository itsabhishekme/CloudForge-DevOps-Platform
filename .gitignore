# ==========================================================
# CloudForge DevOps Platform
# Global .gitignore
# ==========================================================

# ----------------------------------------------------------
# Dependencies
# ----------------------------------------------------------
node_modules/
**/node_modules/

# ----------------------------------------------------------
# Next.js
# ----------------------------------------------------------
.next/
out/

# ----------------------------------------------------------
# Build Output
# ----------------------------------------------------------
dist/
build/
coverage/
*.tsbuildinfo

# ----------------------------------------------------------
# Logs
# ----------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----------------------------------------------------------
# Environment Files
# ----------------------------------------------------------
.env
.env.*
!.env.example
!.env.template

# ----------------------------------------------------------
# IDE
# ----------------------------------------------------------
.vscode/
.idea/
*.code-workspace

# ----------------------------------------------------------
# Operating System
# ----------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ----------------------------------------------------------
# Git
# ----------------------------------------------------------
.gitmodules

# ----------------------------------------------------------
# Docker
# ----------------------------------------------------------
docker-data/
mongo-data/
grafana-data/
prometheus-data/
elasticsearch-data/
jenkins_home/
*.pid

# ----------------------------------------------------------
# Terraform
# ----------------------------------------------------------
.terraform/
**/.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log
terraform.tfvars
*.auto.tfvars
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform.lock.hcl

# ----------------------------------------------------------
# Kubernetes
# ----------------------------------------------------------
kubeconfig
*.kubeconfig

# ----------------------------------------------------------
# AWS
# ----------------------------------------------------------
.aws/
aws-credentials

# ----------------------------------------------------------
# Testing
# ----------------------------------------------------------
coverage/
.nyc_output/

# ----------------------------------------------------------
# Temporary Files
# ----------------------------------------------------------
tmp/
temp/
.cache/
*.tmp
*.bak
*.swp
*.swo

# ----------------------------------------------------------
# Package Managers
# ----------------------------------------------------------
.pnpm-store/
.yarn/
.yarn-cache/
.yarnrc.yml

# ----------------------------------------------------------
# Miscellaneous
# ----------------------------------------------------------
*.zip
*.tar
*.gz
*.rar

# ----------------------------------------------------------
# Python (if used for automation/scripts)
# ----------------------------------------------------------
__pycache__/
*.pyc

# ----------------------------------------------------------
# Java (Jenkins plugins or tools)
# ----------------------------------------------------------
*.class
target/

# ----------------------------------------------------------
# Editor Settings
# ----------------------------------------------------------
.history/